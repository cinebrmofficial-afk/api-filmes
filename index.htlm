<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Filmes</title>
</head>

<body>

<h1>Filmes</h1>

<div id="lista"></div>

<script>

const api="https://raw.githubusercontent.com/cinebrmofficial-afk/api-filmes/main/filmes.json"

async function carregar(){

const r=await fetch(api)
const filmes=await r.json()

const lista=document.getElementById("lista")

filmes.forEach(f=>{

const div=document.createElement("div")

div.innerHTML=`
<h3>${f.nome}</h3>
<img src="${f.imagem}" width="200">
<br>
<a href="${f.link}" target="_blank">Assistir</a>
<hr>
`

lista.appendChild(div)

})

}

carregar()

</script>

</body>
</html>