            <div class="menu-item">
                <div class="menu-icon">❤️</div>
                <div class="menu-text">
                    <h4>My Likes</h4>
                    <p>Filmes que você curtiu</p>
                </div>
                <span class="arrow">›</span>
            </div>

            <div class="menu-item">
                <div class="menu-icon">🕐</div>
