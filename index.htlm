        <div class="version-info">
            <p>BRM v2.0.1 - TMDB Edition</p>
            <p style="margin-top: 5px;">Made with ❤️ Pro Max</p>
        </div>
    </div>

    <!-- BOTTOM NAVIGATION -->
    <div class="bottom-nav">
        <div class="nav-item active" onclick="showPage('home', this)">
            <span class="nav-icon">🌐</span>
            Home
        </div>
        <div class="nav-item" onclick="showPage('premium', this)">
            <span class="nav-icon">🏆</span>
            Premium
        </div>
        <div class="nav-item" onclick="showPage('downloads', this)">
            <span class="nav-icon">⚡</span>
            Downloads
        </div>
        <div class="nav-item" onclick="showPage('me', this)">
            <span class="nav-icon">🗽</span>
            Me
        </div>
    </div>

    <script>
        // ==========================================
        // CONFIGURAÇÃO TMDB - BEARER TOKEN
        // ==========================================
        const BEARER_TOKEN = 'eyJhbGciOiJIUzI1NiJ9.eyJhdWQiOiI1Nzk5MjYyNDk5ZjMwNTEyM2Y2OWM0MTljMmExMzFlNiIsIm5iZiI6MTc3MjgzMzU2Ni4wMzgsInN1YiI6IjY5YWI0YjFlYTE1NGRhMTQyZWZkMDI1YSIsInNjb3BlcyI6WyJhcGlfcmVhZCJdLCJ2ZXJzaW9uIjoxfQ.ZehX9D-LG8Q5r8J-W1IIMIbYPJF4hxpa0OGKdgaWhj8';
        
        const TMDB_BASE_URL = 'https://api.themoviedb.org/3';
        const TMDB_IMG_URL = 'https://image.tmdb.org/t/p/w200';
        const TMDB_BACKDROP_URL = 'https://image.tmdb.org/t/p/original';

        // Headers para autenticação
        const headers = {
            'Authorization': `Bearer ${BEARER_TOKEN}`,
            'accept': 'application/json'
        };

        // Dados em cache
        let moviesCache = {
            popular: [],
            top_rated: [],
            now_playing: [],
            upcoming: []
        };

        // ==========================================
        // CARREGAR FILMES DO TMDB
        // ==========================================
        async function loadMoviesFromTMDB() {
            try {
                const endpoints = [
                    { key: 'popular', url: '/movie/popular' },
                    { key: 'top_rated', url: '/movie/top_rated' },
                    { key: 'now_playing', url: '/movie/now_playing' },
                    { key: 'upcoming', url: '/movie/upcoming' }
                ];
                
                for (let endpoint of endpoints) {
                    const response = await fetch(
                        `${TMDB_BASE_URL}${endpoint.url}?language=pt-BR&page=1`,
                        { headers: headers }
                    );
                    
                    if (!response.ok) {
                        console.error(`Erro em ${endpoint.key}:`, response.status);
                        continue;
                    }
                    
                    const data = await response.json();
                    moviesCache[endpoint.key] = data.results || [];
                }

                renderAllMovies();
                setupCarousel();
                
                // Esconde loading
                document.getElementById('loading').classList.add('hidden');
                
            } catch (error) {
                console.error('Erro TMDB:', error);
                useDemoData();
            }
        }

        // ==========================================
        // DADOS DE DEMONSTRAÇÃO (fallback)
        // ==========================================
        function useDemoData() {
            const demoMovies = [
                { id: 1, title: "Duna: Parte 2", poster_path: "/1pdfLvkbY9ohJlCjQH2CZjjYVvJ.jpg", backdrop_path: "/xOMo8BRK7PfcJv9JCnx7s5hj0PX.jpg", vote_average: 8.2, release_date: "2024", overview: "Paul Atreides se une aos Fremen..." },
                { id: 2, title: "Deadpool & Wolverine", poster_path: "/8cdWjvZQUExUUTzyp4t6ESMHiRM.jpg", backdrop_path: "/yDHYTfA3R0jFYba16jBB1ef8oIt.jpg", vote_average: 7.9, release_date: "2024", overview: "Wolverine está se recuperando..." },
                { id: 3, title: "Divertida Mente 2", poster_path: "/9gLhu8UFPZfH2Hv11JdKA.jpg", backdrop_path: "/stKGOm8UyhuLPR9sZLjs5A2nAeI.jpg", vote_average: 7.6, release_date: "2024", overview: "Riley agora é adolescente..." },
                { id: 4, title: "Furiosa", poster_path: "/iADOJ8Zymht2vPMh2rBFDqn5f2.jpg", backdrop_path: "/wNAhuOZ3Zf84jCIlrcI6RxhOwv7.jpg", vote_average: 7.7, release_date: "2024", overview: "A jovem Furiosa é raptada..." },
                { id: 5, title: "Godzilla x Kong", poster_path: "/tMefBSflR6PGQLv7WvFPpKLZkyk.jpg", backdrop_path: "/1pdfLvkbY9ohJlCjQH2CZjjYVvJ.jpg", vote_average: 7.2, release_date: "2024", overview: "Godzilla e Kong se unem..." },
                { id: 6, title: "Bad Boys 4", poster_path: "/yF1eOka9vImII76FhBzL9n1n8v.jpg", backdrop_path: "/9gLhu8UFPZfH2Hv11JdKA.jpg", vote_average: 7.0, release_date: "2024", overview: "Os detetives Mike e Marcus..." },
                { id: 7, title: "Planeta dos Macacos", poster_path: "/gKkl37BQuKTanygYQG1pyYgLVgf.jpg", backdrop_path: "/stKGOm8UyhuLPR9sZLjs5A2nAeI.jpg", vote_average: 7.3, release_date: "2024", overview: "Muitos anos depois do reinado..." },
                { id: 8, title: "Garfield", poster_path: "/xYduFGuch9OwbCOEUaanhmtdsW6.jpg", backdrop_path: "/wNAhuOZ3Zf84jCIlrcI6RxhOwv7.jpg", vote_average: 6.5, release_date: "2024", overview: "Garfield se reúne com seu pai..." },
                { id: 9, title: "Um Lugar Silencioso", poster_path: "/9gLhu8UFPZfH2Hv11JdKA.jpg", backdrop_path: "/yOMo8BRK7PfcJv9JCnx7s5hj0PX.jpg", vote_average: 7.1, release_date: "2024", overview: "A jovem Sam deve enfrentar..." },
                { id: 10, title: "Twisters", poster_path: "/pZ8SS4J8p1E8W5P9k3k3k3k3.jpg", backdrop_path: "/xOMo8BRK7PfcJv9JCnx7s5hj0PX.jpg", vote_average: 7.4, release_date: "2024", overview: "Kate Carter é uma ex-caçadora..." }
            ];

            moviesCache.popular = demoMovies;
            moviesCache.top_rated = demoMovies.slice().reverse();
            moviesCache.now_playing = demoMovies.slice(2, 8);
            moviesCache.upcoming = demoMovies.slice(5, 10);

            renderAllMovies();
            setupCarousel();
            document.getElementById('loading').classList.add('hidden');
        }

        // ==========================================
        // RENDERIZAR FILMES
        // ==========================================
        function renderAllMovies() {
            renderMovieRow('populares', moviesCache.popular);
            renderMovieRow('baixados', moviesCache.top_rated);
            renderMovieRow('cartaz', moviesCache.now_playing);
            renderMovieRow('lancamentos', moviesCache.upcoming);
        }

        function renderMovieRow(elementId, movies) {
            const container = document.getElementById(elementId);
            if (!movies || movies.length === 0) {
                container.innerHTML = '<div style="padding: 20px; color: #666;">Nenhum filme encontrado</div>';
                return;
            }

            container.innerHTML = movies.map(movie => `
                <div class="movie-card" onclick="showMovieDetails(${movie.id})">
                    <div class="rating">⭐ ${movie.vote_average?.toFixed(1) || '0.0'}</div>
                    <img src="${movie.poster_path ? TMDB_IMG_URL + movie.poster_path : 'https://via.placeholder.com/110x165/222/00d4ff?text=' + (movie.title ? movie.title[0] : 'X')}" 
                         alt="${movie.title || 'Filme'}"
                         onerror="this.src='https://via.placeholder.com/110x165/222/00d4ff?text=${movie.title ? movie.title[0] : 'X'}'">
                    <div class="title">${movie.title || 'Sem título'}</div>
                </div>
            `).join('');
        }

        // ==========================================
        // CAROUSEL DESTAQUE
        // ==========================================
        function setupCarousel() {
            const carousel = document.getElementById('carousel');
            const movies = moviesCache.popular.slice(0, 5);
            
            if (movies.length === 0) return;
            
            // Cria slides
            movies.forEach((movie, index) => {
                const slide = document.createElement('div');
                slide.className = `carousel-slide ${index === 0 ? 'active' : ''}`;
                
                const bgImage = movie.backdrop_path 
                    ? TMDB_BACKDROP_URL + movie.backdrop_path 
                    : (movie.poster_path ? TMDB_IMG_URL + movie.poster_path : '');
                
                slide.style.backgroundImage = `url(${bgImage})`;
                
                slide.innerHTML = `
                    <div class="carousel-overlay"></div>
                    <div class="carousel-info">
                        <h2>${movie.title || 'Filme'}</h2>
                        <div class="meta">
                            <span>⭐ ${movie.vote_average?.toFixed(1) || '0.0'}</span>
                            <span>${movie.release_date ? movie.release_date.split('-')[0] : '2024'}</span>
                        </div>
                        <div class="overview">${movie.overview ? movie.overview.substring(0, 100) + '...' : 'Sem sinopse disponível.'}</div>
                    </div>
                `;
                
                carousel.insertBefore(slide, document.getElementById('carousel-dots'));
            });

            // Cria dots
            const dotsContainer = document.getElementById('carousel-dots');
            dotsContainer.innerHTML = movies.map((_, i) => 
                `<div class="dot ${i === 0 ? 'active' : ''}" onclick="goToSlide(${i})"></div>`
            ).join('');

            // Auto-play
            setInterval(nextSlide, 4000);
        }

        let currentSlide = 0;
        function goToSlide(n) {
            const slides = document.querySelectorAll('.carousel-slide');
            const dots = document.querySelectorAll('.dot');
            
            if (slides.length === 0) return;
            
            slides[currentSlide]?.classList.remove('active');
            dots[currentSlide]?.classList.remove('active');
            
            currentSlide = n;
            
            slides[currentSlide]?.classList.add('active');
            dots[currentSlide]?.classList.add('active');
        }

        function nextSlide() {
            const slides = document.querySelectorAll('.carousel-slide');
            if (slides.length > 0) {
                goToSlide((currentSlide + 1) % slides.length);
            }
        }

        // ==========================================
        // NAVEGAÇÃO
        // ==========================================
        function showPage(page, btn) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            
            document.getElementById(`page-${page}`).classList.add('active');
            btn.classList.add('active');
        }

        // ==========================================
        // BUSCA
        // ==========================================
        async function searchMovies() {
            const query = document.getElementById('searchInput').value.trim();
            if (!query) return;

            try {
                document.getElementById('loading').classList.remove('hidden');
                
                const response = await fetch(
                    `${TMDB_BASE_URL}/search/movie?query=${encodeURIComponent(query)}&language=pt-BR&page=1`,
                    { headers: headers }
                );
                
                if (!response.ok) throw new Error('Erro na busca');
                
                const data = await response.json();
                
                // Mostra resultados na seção populares temporariamente
                renderMovieRow('populares', data.results || []);
                
                document.getElementById('loading').classList.add('hidden');
                
            } catch (error) {
                console.error('Erro busca:', error);
                alert('Erro na busca. Usando dados locais.');
                document.getElementById('loading').classList.add('hidden');
            }
        }

        // Enter na busca
        document.getElementById('searchInput')?.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') searchMovies();
        });

        // ==========================================
        // DETALHES DO FILME
        // ==========================================
        function showMovieDetails(movieId) {
            const allMovies = [...moviesCache.popular, ...moviesCache.top_rated, ...moviesCache.now_playing, ...moviesCache.upcoming];
            const movie = allMovies.find(m => m.id === movieId);
            
            if (movie) {
                alert(`🎬 ${movie.title || 'Filme'}\n\n⭐ Avaliação: ${movie.vote_average || 'N/A'}\n📅 Lançamento: ${movie.release_date || 'N/A'}\n\n${movie.overview ? movie.overview.substring(0, 150) + '...' : 'Sem sinopse.'}`);
            }
        }

        // ==========================================
        // CATEGORIAS
        // ==========================================
        async function filterCategory(genreId, element) {
            document.querySelectorAll('.cat-item').forEach(c => c.classList.remove('active'));
            element.classList.add('active');

            if (genreId === 'all') {
                renderAllMovies();
                return;
            }

            try {
                document.getElementById('loading').classList.remove('hidden');
                
                const response = await fetch(
                    `${TMDB_BASE_URL}/discover/movie?with_genres=${genreId}&language=pt-BR&page=1`,
                    { headers: headers }
                );
                
                if (!response.ok) throw new Error('Erro no filtro');
                
                const data = await response.json();
                renderMovieRow('populares', data.results || []);
                
                document.getElementById('loading').classList.add('hidden');
                
            } catch (error) {
                console.error('Erro filtro:', error);
                alert('Erro ao filtrar. Tente novamente.');
                document.getElementById('loading').classList.add('hidden');
            }
        }

        function loadMore(type) {
            alert(`Carregar mais filmes: ${type}\n\nNa versão completa, isso carregaria a página 2 da API.`);
        }

        // ==========================================
        // DOWNLOADS FUNCTIONS
        // ==========================================
        function toggleOptions(btn) {
            const menu = btn.closest('.download-item').querySelector('.options-menu');
            document.querySelectorAll('.options-menu').forEach(m => {
                if(m !== menu) m.classList.remove('show');
            });
            menu.classList.toggle('show');
        }

        function deleteDownload(el) {
            el.closest('.download-item').remove();
        }

        function cancelDownload(el) {
            alert('Download cancelado!');
            el.closest('.options-menu').classList.remove('show');
        }

        function helpDownload(el) {
            alert('Ajuda: Verifique sua conexão WiFi');
            el.closest('.options-menu').classList.remove('show');
        }

        function switchTab(tab, type) {
            document.querySelectorAll('.storage-tab').forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
        }

        // Fecha menus ao clicar fora
        document.addEventListener('click', (e) => {
            if(!e.target.closest('.download-item')) {
                document.querySelectorAll('.options-menu').forEach(m => m.classList.remove('show'));
            }
        });

        // ==========================================
        // INICIAR
        // ==========================================
        document.addEventListener('DOMContentLoaded', loadMoviesFromTMDB);
    </script>

</body>
</html>
