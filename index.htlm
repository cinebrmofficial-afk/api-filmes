                    <p>Suas publicações</p>
                </div>
                <span class="arrow">›</span>
            </div>

            <div class="menu-item">
                <div class="menu-icon">💭</div>
                <div class="menu-text">
                    <h4>Meus Comentários</h4>
                    <p>Comentários em filmes</p>
                </div>
                <span class="arrow">›</span>
            </div>

            <div class="menu-item">
                <div class="menu-icon">📩</div>
                <div class="menu-text">
                    <h4>Feedback</h4>
                    <p>Envie sua opinião</p>
                </div>
                <span class="arrow">›</span>
            </div>

            <div class="settings-section">
                <div class="menu-item">
                    <div class="menu-icon">⚙️</div>
                    <div class="menu-text">
                        <h4>Definições</h4>
                        <p>Configurações do app</p>
                    </div>
                    <span class="arrow">›</span>
                </div>

                <div class="menu-item">
                    <div class="menu-icon">🔗</div>
                    <div class="menu-text">
                        <h4>Official Website</h4>
                        <p>BRM.ph - Copy link</p>
