            <div class="menu-item">
                <div class="menu-icon">💬</div>
                <div class="menu-text">
                    <h4>Messages</h4>
                    <p>Suas conversas</p>
                </div>
                <span class="arrow">›</span>
            </div>

            <div class="menu-item">
                <div class="menu-icon">🌐</div>
