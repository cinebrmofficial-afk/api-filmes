            <div class="options-menu">
                <div class="option-item delete" onclick="deleteDownload(this)">🗑️ Apagar</div>
                <div class="option-item" onclick="cancelDownload(this)">✕ Cancelar</div>
                <div class="option-item" onclick="helpDownload(this)">❓ Ajuda</div>
            </div>
        </div>

        <div class="download-item">
            <div class="download-header">
                <div>
                    <div class="download-title">🎬 Duna: Parte 2 720p</div>
                    <div class="download-meta">WiFi • Baixando...</div>
                </div>
                <span class="manage-btn" onclick="toggleOptions(this)">⋮</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: 45%;"></div>
            </div>
            <div class="download-stats">
                <span>420.1 MB / 933.5 MB</span>
                <span>45%</span>
            </div>
            <span class="status-badge status-downloading">⬇️ Downloading</span>
            
            <div class="options-menu">
                <div class="option-item delete" onclick="deleteDownload(this)">🗑️ Apagar</div>
                <div class="option-item" onclick="cancelDownload(this)">✕ Cancelar</div>
                <div class="option-item" onclick="helpDownload(this)">❓ Ajuda</div>
            </div>
        </div>

        <div style="padding: 20px; border-top: 1px solid #222; margin-top: 20px;">
            <h3 style="margin-bottom: 15px;">📁 Arquivos Baixados</h3>
            
            <div class="storage-tabs">
                <div class="storage-tab active" onclick="switchTab(this, 'brm')">
                    <div class="icon">📱</div>
                    <div class="name">BRM</div>
                    <div class="count">(1) arquivo</div>
                </div>
                <div class="storage-tab" onclick="switchTab(this, 'local')">
                    <div class="icon">💾</div>
                    <div class="name">Local</div>
                    <div class="count">Celular</div>
                </div>
                <div class="storage-tab" onclick="switchTab(this, 'received')">
                    <div class="icon">📥</div>
                    <div class="name">Receive</div>
                    <div class="count">Transferido</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ME PAGE -->
    <div class="page" id="page-me">
        <div class="me-header">
            <div class="me-avatar">👤</div>
            <h3>Log in your account</h3>
            <p style="color: #666; font-size: 13px; margin-top: 5px;">ID: null</p>
            <button class="login-btn">Entrar</button>
        </div>

        <div class="menu-list">
            <div class="menu-item">
                <div class="menu-icon">👨‍👩‍👧‍👦</div>
