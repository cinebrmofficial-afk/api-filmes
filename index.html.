    <script>
        // ================= COLE AQUI O CÓDIGO JAVASCRIPT QUE VOCÊ ENVIOU =================
        // ✅ CONFIGURAÇÃO TMDB COM SUA CHAVE
        const CONFIG = {
            API_KEY: '5799262499f305123f69c419c2a131e6', // Sua chave
            BASE_URL: 'https://api.themoviedb.org/3',
            IMAGE_URL: 'https://image.tmdb.org/t/p/w500',
            BACKDROP_URL: 'https://image.tmdb.org/t/p/original',
            LANGUAGE: 'pt-BR'
        };

        // Estado global
        let currentPage = 'home';
        let downloads = JSON.parse(localStorage.getItem('downloads')) || [];
        let userPoints = parseInt(localStorage.getItem('points')) || 1250;
        let currentMovie = null;
        let allMovies = []; // Cache global

        // Dados fallback (se API falhar)
        const mockMovies = [
            { id: 1, title: "A Origem", year: 2010, rating: 8.4, genre: "Ficção", duration: "2h 28min", image: "https://image.tmdb.org/t/p/w500/ljsZTbVsrQSqZgWeep2B1QiDKuh.jpg", backdrop: "https://image.tmdb.org/t/p/original/8ZTVqvKDQ8emSGUEMjsS4yHAwrp.jpg", description: "Um ladrão que rouba segredos corporativos através da tecnologia de compartilhamento de sonhos.", cast: ["Leonardo DiCaprio", "Joseph Gordon-Levitt"] },
            { id: 2, title: "O Cavaleiro das Trevas", year: 2008, rating: 9.0, genre: "Ação", duration: "2h 32min", image: "https://image.tmdb.org/t/p/w500/qJ2tW6WMUDux911r6m7haRef0WH.jpg", backdrop: "https://image.tmdb.org/t/p/original/nMKdUUepR0i5zn0y1T4CsSB5chy.jpg", description: "Batman enfrenta o Coringa, um criminoso que quer mergulhar Gotham na anarquia.", cast: ["Christian Bale", "Heath Ledger"] }
        ];

        // Inicialização
        document.addEventListener('DOMContentLoaded', async () => {
            showToast('Carregando filmes...', 'info');
            await loadMovies();
            updatePointsDisplay();
            renderDownloads();
            setupEventListeners();
            
            // Verificar se API está funcionando
            if (allMovies.length === 0) {
                showToast('Usando dados offline', 'error');
                allMovies = mockMovies;
                renderMovies();
            }
        });

        // 🎬 FUNÇÕES DA API TMDB

        async function loadMovies() {
            try {
                // Buscar dados em paralelo
                const [popular, nowPlaying, topRated] = await Promise.all([
                    fetchFromAPI('/movie/popular'),
                    fetchFromAPI('/movie/now_playing'),
                    fetchFromAPI('/movie/top_rated')
                ]);
                
                // Combinar e remover duplicatas
                const combined = [...popular, ...nowPlaying, ...topRated];
                allMovies = removeDuplicates(combined);
                
                renderMovies();
                
                // Atualizar hero com primeiro filme popular
                if (popular.length > 0) {
                    updateHero(popular[0]);
                }
                
                showToast('Filmes carregados!', 'success');
            } catch (error) {
                console.error('Erro API:', error);
                allMovies = mockMovies;
                renderMovies();
            }
        }

        async function fetchFromAPI(endpoint) {
            const url = `${CONFIG.BASE_URL}${endpoint}?api_key=${CONFIG.API_KEY}&language=${CONFIG.LANGUAGE}&page=1`;
            const response = await fetch(url);
            if (!response.ok) throw new Error('API Error');
            const data = await response.json();
            return data.results.map(normalizeMovie);
        }

        function normalizeMovie(movie) {
            return {
                id: movie.id,
                title: movie.title,
                year: movie.release_date ? new Date(movie.release_date).getFullYear() : 'N/A',
                rating: movie.vote_average ? movie.vote_average.toFixed(1) : 'N/A',
                genre: getGenreName(movie.genre_ids?.[0]),
                duration: '2h 00min', // Será atualizado nos detalhes
                image: movie.poster_path ? `${CONFIG.IMAGE_URL}${movie.poster_path}` : 'https://via.placeholder.com/500x750?text=Sem+Imagem',
                backdrop: movie.backdrop_path ? `${CONFIG.BACKDROP_URL}${movie.backdrop_path}` : null,
                description: movie.overview || 'Sinopse não disponível.',
                genre_ids: movie.genre_ids || []
            };
        }

        function getGenreName(id) {
            const genres = {
                28: 'Ação', 12: 'Aventura', 16: 'Animação', 35: 'Comédia',
                80: 'Crime', 99: 'Documentário', 18: 'Drama', 10751: 'Família',
                14: 'Fantasia', 36: 'História', 27: 'Terror', 10402: 'Música',
                9648: 'Mistério', 10749: 'Romance', 878: 'Ficção Científica',
                10770: 'Cinema TV', 53: 'Thriller', 10752: 'Guerra', 37: 'Faroeste'
            };
            return genres[id] || 'Filme';
        }

        function removeDuplicates(movies) {
            const seen = new Set();
            return movies.filter(movie => {
                const duplicate = seen.has(movie.id);
                seen.add(movie.id);
                return !duplicate;
            });
        }

        // 🎨 RENDERIZAÇÃO

        function renderMovies() {
            const popularContainer = document.getElementById('popular-movies');
            const newContainer = document.getElementById('new-movies');
            const recommendedContainer = document.getElementById('recommended-movies');
            
            // Limpar
            [popularContainer, newContainer, recommendedContainer].forEach(c => c.innerHTML = '');
            
            // Distribuir filmes (primeiros 8 populares, próximos 6 novos, etc)
            allMovies.forEach((movie, index) => {
                const card = createMovieCard(movie);
                
                if (index < 8) {
                    popularContainer.innerHTML += card;
                } else if (index < 14) {
                    newContainer.innerHTML += card;
                } else if (index < 20) {
                    recommendedContainer.innerHTML += card;
                }
            });
        }

        function createMovieCard(movie) {
            return `
                <div class="movie-card" onclick="showMovieDetails(${movie.id})">
                    <img src="${movie.image}" alt="${movie.title}" loading="lazy" onerror="this.src='https://via.placeholder.com/500x750?text=Erro'">
                    <div class="rating"><i class="fas fa-star"></i> ${movie.rating}</div>
                    <div class="title">${movie.title}</div>
                </div>
            `;
        }

        function updateHero(movie) {
            const hero = document.getElementById('hero');
            if (movie.backdrop) {
                hero.querySelector('.hero-bg').src = movie.backdrop;
            }
            hero.querySelector('.hero-title').textContent = movie.title;
            hero.querySelector('.hero-meta').innerHTML = `
                <span><i class="fas fa-star"></i> ${movie.rating}</span>
                <span>${movie.year}</span>
                <span>${movie.duration}</span>
                <span>${movie.genre}</span>
            `;
            hero.querySelector('.hero-buttons').innerHTML = `
                <button class="btn btn-primary" onclick="playMovie('${movie.title}')">
                    <i class="fas fa-play"></i> Assistir
                </button>
                <button class="btn btn-secondary" onclick="showMovieDetails(${movie.id})">
                    <i class="fas fa-info-circle"></i> Info
                </button>
            `;
        }

        // 🔍 DETALHES DO FILME (COM CREDITS)

        async function showMovieDetails(movieId) {
            // Verificar cache primeiro
            let movie = allMovies.find(m => m.id === movieId);
            
            if (!movie) {
                showToast('Filme não encontrado', 'error');
                return;
            }
            
            currentMovie = movie;
            showToast('Carregando detalhes...', 'info');
            
            try {
                // Buscar detalhes completos + elenco
                const [detailsRes, creditsRes] = await Promise.all([
                    fetch(`${CONFIG.BASE_URL}/movie/${movieId}?api_key=${CONFIG.API_KEY}&language=${CONFIG.LANGUAGE}`),
                    fetch(`${CONFIG.BASE_URL}/movie/${movieId}/credits?api_key=${CONFIG.API_KEY}&language=${CONFIG.LANGUAGE}`)
                ]);
                
                const details = await detailsRes.json();
                const credits = await creditsRes.json();
                
                // Atualizar dados
                movie.duration = details.runtime ? `${Math.floor(details.runtime/60)}h ${details.runtime%60}min` : 'N/A';
                movie.description = details.overview || movie.description;
                movie.cast = credits.cast?.slice(0, 6).map(a => a.name) || movie.cast || [];
                
                openModal(movie);
            } catch (error) {
                console.error('Erro detalhes:', error);
                // Abrir com dados básicos mesmo se falhar
                openModal(movie);
            }
        }

        function openModal(movie) {
            document.getElementById('modal-img').src = movie.backdrop || movie.image;
            document.getElementById('modal-title').textContent = movie.title;
            document.getElementById('modal-rating').textContent = movie.rating;
            document.getElementById('modal-year').textContent = movie.year;
            document.getElementById('modal-duration').textContent = movie.duration;
            document.getElementById('modal-genre').textContent = movie.genre;
            document.getElementById('modal-description').textContent = movie.description;
            
            // Elenco
            const castContainer = document.getElementById('modal-cast');
            if (movie.cast && movie.cast.length > 0) {
                castContainer.innerHTML = movie.cast.map(actor => `
                    <div class="cast-item">
                        <div style="width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: white;">
                            <i class="fas fa-user"></i>
                        </div>
                        <div class="name" style="font-size: 12px; margin-top: 5px;">${actor}</div>
                    </div>
                `).join('');
            } else {
                castContainer.innerHTML = '<p style="color: var(--text-secondary); font-size: 14px;">Elenco não disponível</p>';
            }
            
            // Botão download
            const isDownloaded = downloads.some(d => d.id === movie.id);
            const downloadBtn = document.getElementById('modal-download-btn');
            downloadBtn.classList.remove('downloading');
            downloadBtn.style.background = isDownloaded ? 'var(--success)' : 'rgba(255,255,255,0.1)';
            downloadBtn.innerHTML = isDownloaded ? '<i class="fas fa-check"></i>' : '<i class="fas fa-download"></i>';
            
            document.getElementById('movie-modal').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        // 🔍 BUSCA

        async function searchMovies(query) {
            if (!query || query.length < 2) {
                loadMovies(); // Restaurar original
                return;
            }
            
            showToast('Buscando...', 'info');
            
            try {
                const url = `${CONFIG.BASE_URL}/search/movie?api_key=${CONFIG.API_KEY}&language=${CONFIG.LANGUAGE}&query=${encodeURIComponent(query)}`;
                const response = await fetch(url);
                const data = await response.json();
                
                if (data.results && data.results.length > 0) {
                    allMovies = data.results.map(normalizeMovie);
                    renderMovies();
                    showToast(`${data.results.length} filmes encontrados`, 'success');
                } else {
                    showToast('Nenhum filme encontrado', 'error');
                }
            } catch (error) {
                console.error('Erro busca:', error);
                showToast('Erro na busca', 'error');
            }
        }

        // 💾 DOWNLOADS

        function downloadMovieFromModal() {
            if (!currentMovie) return;
            
            if (downloads.some(d => d.id === currentMovie.id)) {
                showToast('Já baixado!', 'info');
                return;
            }
            
            const btn = document.getElementById('modal-download-btn');
            btn.classList.add('downloading');
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            
            setTimeout(() => {
                downloads.unshift({
                    ...currentMovie,
                    size: '1.5 GB',
                    quality: '1080p',
                    downloadedAt: new Date().toISOString()
                });
                localStorage.setItem('downloads', JSON.stringify(downloads));
                
                btn.classList.remove('downloading');
                btn.innerHTML = '<i class="fas fa-check"></i>';
                btn.style.background = 'var(--success)';
                
                renderDownloads();
                addPoints(50);
                showToast('Download concluído!', 'success');
            }, 1500);
        }

        function deleteDownload(id) {
            downloads = downloads.filter(d => d.id !== id);
            localStorage.setItem('downloads', JSON.stringify(downloads));
            renderDownloads();
            showToast('Removido', 'success');
        }

        function renderDownloads() {
            const container = document.getElementById('downloads-list');
            const empty = document.getElementById('empty-downloads');
            
            if (downloads.length === 0) {
                container.innerHTML = '';
                empty.style.display = 'block';
                return;
            }
            
            empty.style.display = 'none';
            container.innerHTML = downloads.map(m => `
                <div class="download-item">
                    <img src="${m.image}" class="download-thumb" alt="${m.title}">
                    <div class="download-info">
                        <div class="download-title">${m.title}</div>
                        <div class="download-meta">${m.quality || '1080p'} • ${m.size}</div>
                        <div class="download-progress">
                            <div class="progress-bar"><div class="progress-fill" style="width: 100%"></div></div>
                            <span class="progress-text">100%</span>
                        </div>
                    </div>
                    <div class="download-actions">
                        <i class="fas fa-play" onclick="playMovie('${m.title}')"></i>
                        <i class="fas fa-trash" onclick="deleteDownload(${m.id})"></i>
                    </div>
                </div>
            `).join('');
        }

        // 🎮 CONTROLES

        function addPoints(amount) {
            userPoints += amount;
            localStorage.setItem('points', userPoints);
            updatePointsDisplay();
        }

        function updatePointsDisplay() {
            const els = document.querySelectorAll('#user-points, #stat-points');
            els.forEach(el => {
                if (el) el.textContent = `${userPoints.toLocaleString()} pontos`;
            });
        }

        function navigate(page) {
            document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            
            event.currentTarget.classList.add('active');
            document.getElementById(`page-${page}`).classList.add('active');
            currentPage = page;
            window.scrollTo(0, 0);
        }

        function closeModal() {
            document.getElementById('movie-modal').classList.remove('active');
            document.body.style.overflow = '';
        }

        function playMovie(title) {
            showToast(`Iniciando: ${title}`, 'success');
        }

        function playMovieFromModal() {
            if (currentMovie) playMovie(currentMovie.title);
        }

        function selectPlan(plan) {
            showToast(`Plano ${plan} selecionado!`, 'success');
        }

        function filterByCategory(category) {
            if (category === 'all') {
                loadMovies();
                return;
            }
            // Filtrar por gênero (simplificado)
            const filtered = allMovies.filter(m => 
                m.genre.toLowerCase().includes(category) || 
                m.genre_ids?.includes(parseInt(category))
            );
            if (filtered.length > 0) {
                allMovies = filtered;
                renderMovies();
            }
        }

        // 🔔 TOAST

        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            const msg = document.getElementById('toast-message');
            const icon = toast.querySelector('.toast-icon');
            
            toast.className = `toast ${type}`;
            msg.textContent = message;
            
            const icons = { success: 'fa-check-circle', error: 'fa-exclamation-circle', info: 'fa-info-circle' };
            icon.className = `toast-icon fas ${icons[type]}`;
            
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        // 🎧 EVENT LISTENERS

        function setupEventListeners() {
            // Busca com debounce
            let timeout;
            document.getElementById('searchInput').addEventListener('input', (e) => {
                clearTimeout(timeout);
                timeout = setTimeout(() => searchMovies(e.target.value), 500);
            });
            
            // Categorias
            document.querySelectorAll('.cat-item').forEach(cat => {
                cat.addEventListener('click', function() {
                    document.querySelectorAll('.cat-item').forEach(c => c.classList.remove('active'));
                    this.classList.add('active');
                    filterByCategory(this.dataset.cat);
                });
            });
            
            // Fechar modal ao clicar fora
            document.getElementById('movie-modal').addEventListener('click', (e) => {
                if (e.target.id === 'movie-modal') closeModal();
            });
            
            // ESC para fechar
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') closeModal();
            });
        }
    </script>
</body>
</html>
