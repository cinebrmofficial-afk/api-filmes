<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>CineBMR - Oficial</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:sans-serif;background:#0f0f0f;color:#fff;padding-bottom:80px}
        .header{padding:15px;border-bottom:1px solid #333;display:flex;align-items:center;gap:10px}
        .logo{background:linear-gradient(45deg,#00d4ff,#00d084);padding:8px;border-radius:8px;font-weight:bold}
        .search-bar{flex:1;background:#242424;border-radius:20px;padding:8px 15px}
        .search-bar input{background:none;border:none;color:#fff;width:100%;outline:none}
        .main{padding:15px}
        .grid{display:grid;grid-template-columns:repeat(auto-fill, minmax(140px, 1fr));gap:15px}
        .card{background:#1a1a1a;border-radius:12px;overflow:hidden;cursor:pointer}
        .card img{width:100%;aspect-ratio:2/3;object-fit:cover}
        .card-info{padding:8px;font-size:13px;text-align:center}
        .modal{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.9);display:none;align-items:center;justify-content:center;z-index:1000}
        .modal.active{display:flex}
        .modal-content{width:90%;max-width:400px;background:#1a1a1a;padding:20px;border-radius:20px;text-align:center}
        .watch-btn{display:block;background:#00d084;color:#fff;padding:15px;border-radius:10px;text-decoration:none;margin-top:15px;font-weight:bold}
    </style>
</head>
<body>
    <header class="header">
        <div class="logo">CB</div>
        <div class="search-bar"><input type="text" id="search" placeholder="Buscar..." oninput="buscar()"></div>
    </header>
    <div class="main">
        <h3 style="margin-bottom:15px">Lançamentos</h3>
        <div class="grid" id="lista"></div>
    </div>

    <div id="modal" class="modal">
        <div class="modal-content">
            <img id="mImg" style="width:100%;border-radius:10px">
            <h2 id="mTitle" style="margin:10px 0"></h2>
            <a id="mLink" href="#" target="_blank" class="watch-btn">ASSISTIR AGORA</a>
            <button onclick="fechar()" style="background:none;border:none;color:#aaa;margin-top:15px">Fechar</button>
        </div>
    </div>

    <script>
        let db = [];
        async function carregar(){
            const r = await fetch('filmes.json');
            db = await r.json();
            render(db);
        }
        function render(dados){
            document.getElementById('lista').innerHTML = dados.map(m => `
                <div class="card" onclick="abrir('${m.titulo}','${m.imagem}','${m.link}')">
                    <img src="${m.imagem}">
                    <div class="card-info">${m.titulo}</div>
                </div>
            `).join('');
        }
        function buscar(){
            let q = document.getElementById('search').value.toLowerCase();
            render(db.filter(m => m.titulo.toLowerCase().includes(q)));
        }
        function abrir(t,img,l){
            document.getElementById('mTitle').innerText = t;
            document.getElementById('mImg').src = img;
            document.getElementById('mLink').href = l;
            document.getElementById('modal').classList.add('active');
        }
        function fechar(){ document.getElementById('modal').classList.remove('active'); }
        carregar();
    </script>
</body>
</html>
